# Production Environment Variables for RandevuGO
# Copy this to .env and fill with your actual values

# Database (Render PostgreSQL)
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require
DB_HOST=
DB_PORT=5432
DB_NAME=
DB_USER=
DB_PASSWORD=

# Base URLs (Render will provide these)
BASE_URL=https://your-app-name.onrender.com
FRONTEND_URL=https://your-frontend-name.onrender.com

# JWT & Security
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=whatsapp:+1234567890

# DeepSeek AI
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# Telegram (For each business - store in database)
# TELEGRAM_TOKENS stored in isletmeler.telegram_token column

# Redis (Optional - for caching)
REDIS_URL=redis://user:pass@host:port

# Logging
LOG_LEVEL=info
NODE_ENV=production

# Cron Settings
ENABLE_CRON=true
CRON_TIMEZONE=Europe/Istanbul
