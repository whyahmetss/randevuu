# Production Environment Variables for RandevuGO
# Copy this to .env and fill with actual values

# ═══ Database ═══ (Neon.tech PostgreSQL — managed external)
# Signup: https://neon.tech → New Project → Connection String
DATABASE_URL=postgresql://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require

# ═══ Base URLs ═══
BASE_URL=https://randevugo-api-v2.onrender.com
FRONTEND_URL=https://admin.siragO.com
ADMIN_PANEL_URL=https://admin.siragO.com

# ═══ JWT & Security ═══ (en az 32 karakter)
JWT_SECRET=your-super-secret-jwt-key-at-least-32-characters-long

# ═══ WhatsApp (Twilio) ═══ (opsiyonel — baileys/whatsapp-web.js öncelikli)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token
TWILIO_PHONE_NUMBER=whatsapp:+1234567890

# ═══ AI ═══
DEEPSEEK_API_KEY=sk-your-deepseek-api-key

# ═══ Google Maps (Avcı Bot — işletme tarama) ═══
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# ═══ SerpAPI (sosyal medya tarama — Instagram/FB/TikTok) ═══
SERP_API_KEY=your-serp-api-key

# ═══ Shopier (ödeme) ═══
SHOPIER_USERNAME=your-shopier-username
SHOPIER_PASSWORD=your-shopier-password
SHOPIER_RANDOM_KEY=your-shopier-random-key

# ═══ Web Push (VAPID) ═══ (npm'de: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:support@siragO.com

# ═══ Redis (Opsiyonel, cache için) ═══
REDIS_URL=redis://user:pass@host:port

# ═══ Telegram ═══
# Her işletmenin kendi bot token'ı DB'de: isletmeler.telegram_token

# ═══ Logging & Cron ═══
LOG_LEVEL=info
NODE_ENV=production
ENABLE_CRON=true
CRON_TIMEZONE=Europe/Istanbul
